VAR
PROGRAM PLC_PRG
VAR
	rLevel : REAL := 8.0; // tank lvl 0-100
	rSP_Low : REAL := 30.0; // low setpoint
	rSP_High : REAL := 80.0; // hi setpoint
	rSP_AlarmHigh : REAL := 90.0; // highest setpoint
	rSp_AlarmLow : REAL := 10.0;
	xInletValve : BOOL; // TRUE when inlet open
	xPump : BOOL; // TRUE when outlet pump active
	xValveClosed : BOOL;   // TRUE when inlet valve closed
	xPumpStopped : BOOL;   // TRUE when pump stopped
	xStop: BOOL; // stop btn
	xStart: BOOL; // start btn
	xStartPrev : BOOL;
	xStopPrev  : BOOL;
	xFilling : BOOL;
	xAutoMode: BOOL := TRUE; // TRUE=auto, FALSE=manual
	xManualMode: BOOL := FALSE;
	xManInlet: BOOL; // manual inlet cmd
	xManPump : BOOL; // manual pump cmd
	xRunning : BOOL; //running latch
	xHighAlarm : BOOL; // hi lvl alarm
	xLowCutout: BOOL; // dry run protection
	xHighAlarmOk : BOOL;   // TRUE when high alarm NOT active (normal)
	xLowCutoutOk : BOOL;   // TRUE when low cutout NOT active (normal)
	rInflow: REAL;
	rOutflow: REAL;
	xAllOk : BOOL := TRUE;
	xNotOk: BOOL := FALSE;
	xPidMode   : BOOL := TRUE;   // FALSE = on/off, TRUE = PID
	xPidModeOff   : BOOL := TRUE;
	rSP_PID    : REAL := 50.0;    // level target for PID
	rKp        : REAL := 4.5;
	rKi        : REAL := 0.5;
	rKd        : REAL := 0.0;     // start at 0 (PI first)
	rDt        : REAL := 0.1;     // = MainTask cycle (100 ms)
	rError     : REAL;
	rErrPrev   : REAL;
	rIntegral  : REAL;
	rDeriv     : REAL;
	rValveCmd  : REAL;            // 0..100 % inlet opening
	rInflowMax : REAL := 3.0;     // inflow at 100% valve
	rDraw      : REAL := 1.0;     // steady outflow the PID must fight
END_VAR
END_VAR

// start/stop latch (edge-detected)
IF xStart AND NOT xStartPrev THEN xRunning := TRUE; END_IF
IF xStop AND NOT xStopPrev THEN xRunning := FALSE; END_IF
xStartPrev := xStart;
xStopPrev  := xStop;

IF xRunning AND xAutoMode THEN
    IF xPidMode THEN
        // --- PID (modulating inlet valve) ---
        rError    := rSP_PID - rLevel;
        rIntegral := rIntegral + rError * rDt;
        IF rIntegral >  100.0 THEN rIntegral :=  100.0; END_IF   // anti-windup
        IF rIntegral < -100.0 THEN rIntegral := -100.0; END_IF
        rDeriv    := (rError - rErrPrev) / rDt;
        rErrPrev  := rError;
        rValveCmd := rKp*rError + rKi*rIntegral + rKd*rDeriv;
        IF rValveCmd > 100.0 THEN rValveCmd := 100.0; END_IF
        IF rValveCmd < 0.0   THEN rValveCmd := 0.0;   END_IF
    ELSE
        // --- on/off hysteresis ---
        IF rLevel <= rSP_Low  THEN xFilling := TRUE;  END_IF
        IF rLevel >= rSP_High THEN xFilling := FALSE; END_IF
        IF xFilling THEN rValveCmd := 100.0; ELSE rValveCmd := 0.0; END_IF
        xPump := NOT xFilling;
    END_IF
ELSIF xRunning AND NOT xAutoMode THEN
    IF xManInlet THEN rValveCmd := 100.0; ELSE rValveCmd := 0.0; END_IF
    xPump := xManPump;
ELSE
    rValveCmd := 0.0; xPump := FALSE;
END_IF

// --- safety interlocks (re-enabled, run AFTER control) ---
xHighAlarm := rLevel >= rSP_AlarmHigh;
xLowCutout := rLevel <= rSp_AlarmLow;
IF xRunning AND xHighAlarm THEN rValveCmd := 0.0;   END_IF   // overfill -> shut inlet
IF xRunning AND xLowCutout THEN xPump := FALSE;     END_IF   // dry-run -> stop pump

// physics simulation
rInflow := (rValveCmd / 100.0) * rInflowMax;
IF xPidMode THEN
    rOutflow := rDraw;                              // steady disturbance in PID mode
ELSE
    IF xPump THEN rOutflow := 1.5; ELSE rOutflow := 0.0; END_IF
END_IF
rLevel := rLevel + (rInflow - rOutflow) * rDt;

IF rLevel > 100.0 THEN rLevel := 100.0; END_IF
IF rLevel < 0.0   THEN rLevel := 0.0;   END_IF

xInletValve := rValveCmd > 0.0;

xHighAlarmOk := NOT xHighAlarm;
xLowCutoutOk := NOT xLowCutout;
xValveClosed := NOT xInletValve;
xPumpStopped := NOT xPump;
xPidModeOff := NOT xPidMode;
IF xLowCutoutOK = TRUE AND xHighAlarmOk = TRUE THEN xAllOk := TRUE; ELSE xAllOk := FALSE; END_IF
IF xAutoMode = TRUE THEN xManualMode := FALSE; ELSE xManualMode := TRUE; END_IF
